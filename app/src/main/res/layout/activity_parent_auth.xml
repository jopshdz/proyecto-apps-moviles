<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_navy"
    android:padding="28dp">

    <ImageView
        android:id="@+id/ivParentAuthLogo"
        android:layout_width="287dp"
        android:layout_height="303dp"
        android:layout_marginTop="40dp"
        android:contentDescription="Logo KidQuest"
        android:src="@drawable/logo_kidquest"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.45" />

    <TextView
        android:id="@+id/tvAuthTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/fredoka_bold"
        android:text="Portal de Padres"
        android:textColor="@color/neon_yellow"
        android:textSize="34sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/ivParentAuthLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvAuthSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/fredoka_bold"
        android:text="Gestiona las misiones y recompensas de tus pequeños héroes"
        android:textColor="@color/text_white"
        android:textSize="16sp"
        android:textAlignment="center"
        android:alpha="0.8"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvAuthTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="40dp">

        <Button
            android:id="@+id/btnRegisterGoogle"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:backgroundTint="@color/kidquest_gold"
            android:fontFamily="@font/fredoka_bold"
            android:text="Registrarse"
            android:textColor="@color/dark_navy"
            android:textSize="18sp"
            app:cornerRadius="32dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnLoginGoogle"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:backgroundTint="@color/kidquest_blue_mid"
            android:fontFamily="@font/fredoka_bold"
            android:text="Iniciar Sesión"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            app:cornerRadius="32dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/neon_yellow" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>