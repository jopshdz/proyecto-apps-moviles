<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_navy"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="28dp">

        <TextView
            android:id="@+id/tvSetupTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/fredoka_bold"
            android:text="Crea su Perfil"
            android:textColor="@color/neon_yellow"
            android:textSize="32sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/ivSetupAvatar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/nino_log"
            android:contentDescription="Avatar del niño"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.35"
            app:layout_constraintTop_toBottomOf="@id/tvSetupTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAvatarHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/fredoka_bold"
            android:text="Toca para cambiar de Avatar"
            android:textColor="@color/neon_blue"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/ivSetupAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etChildName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/neon_blue"
            android:fontFamily="@font/fredoka_bold"
            android:hint="Nombre o Apodo del aventurero"
            android:inputType="textPersonName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_white"
            android:textColorHint="#80F8FAFC"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tvAvatarHint" />

        <EditText
            android:id="@+id/etChildAge"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/neon_blue"
            android:fontFamily="@font/fredoka_bold"
            android:hint="Edad (Ej. 6 años)"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_white"
            android:textColorHint="#80F8FAFC"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/etChildName" />

        <EditText
            android:id="@+id/etChildBirthday"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/neon_blue"
            android:fontFamily="@font/fredoka_bold"
            android:hint="Cumpleaños (DD/MM/AAAA)"
            android:inputType="date"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_white"
            android:textColorHint="#80F8FAFC"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/etChildAge" />

        <TextView
            android:id="@+id/tvGenderLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/fredoka_bold"
            android:text="¿Eres niño o niña?"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/etChildBirthday"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/llGenderSelector"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvGenderLabel">

            <androidx.cardview.widget.CardView
                android:id="@+id/cvBoy"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A2035"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/fredoka_bold"
                    android:text="👦 NIÑO"
                    android:textColor="#40C4FF"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cvGirl"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A2035"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/fredoka_bold"
                    android:text="👧 NIÑA"
                    android:textColor="#FF4081"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        <Button
            android:id="@+id/btnFinishSetup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="36dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/neon_green"
            android:fontFamily="@font/fredoka_bold"
            android:text="¡Comenzar la Aventura!"
            android:textColor="@color/dark_navy"
            android:textSize="18sp"
            app:cornerRadius="30dp"
            app:layout_constraintTop_toBottomOf="@id/llGenderSelector"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>