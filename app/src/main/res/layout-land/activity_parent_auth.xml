<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_navy"
    android:padding="24dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_auth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.40" />

    <ImageView
        android:id="@+id/ivParentAuthLogo"
        android:layout_width="299dp"
        android:layout_height="330dp"
        android:contentDescription="Logo KidQuest"
        android:src="@drawable/logo_kidquest"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toStartOf="@id/guideline_auth"
        app:layout_constraintHorizontal_bias="0.492"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.3" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline_auth"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAuthTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/fredoka_bold"
            android:text="Portal de Padres"
            android:textAlignment="center"
            android:textColor="@color/neon_yellow"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/tvAuthSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/fredoka_bold"
            android:text="Gestiona las misiones y recompensas de tus pequeños héroes"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textAlignment="center"
            android:alpha="0.8"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnRegisterGoogle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/kidquest_gold"
            android:fontFamily="@font/fredoka_bold"
            android:text="Registrarse"
            android:textColor="@color/dark_navy"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLoginGoogle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/kidquest_blue_mid"
            android:fontFamily="@font/fredoka_bold"
            android:text="Iniciar Sesión"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/neon_yellow"
            app:cornerRadius="28dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>